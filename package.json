{
  "name": "mw-creator-stats",
  "version": "0.1.0",
  "private": true,
  "description": "Interactive dashboard for your MakerWorld Creator Center stats.",
  "license": "MIT",
  "workspaces": [
    "packages/core",
    "packages/ui",
    "packages/web",
    "packages/extension"
  ],
  "scripts": {
    "dev": "yarn workspace @mw/web dev",
    "build": "yarn workspace @mw/web build",
    "build:ext": "yarn workspace @mw/extension build",
    "zip:ext": "yarn workspace @mw/extension zip",
    "watch:ext": "yarn workspace @mw/extension watch",
    "lint": "yarn workspace @mw/web lint",
    "typecheck": "yarn workspaces run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "packageManager": "yarn@1.22.22"
}
