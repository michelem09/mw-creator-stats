{
  "manifest_version": 3,
  "name": "MakerWorld Creator Stats",
  "version": "0.1.0",
  "description": "Full-page analytics dashboard for your MakerWorld Creator Center data. Unofficial.",
  "action": { "default_title": "Open MakerWorld Creator Stats" },
  "background": { "service_worker": "background.js", "type": "module" },
  "permissions": ["storage"],
  "host_permissions": [
    "https://makerworld.com/*",
    "https://*.makerworld.com/*",
    "https://api.anthropic.com/*"
  ]
}
