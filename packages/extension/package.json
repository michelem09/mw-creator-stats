{
  "name": "@mw/extension",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "watch": "vite build --watch",
    "icons": "node scripts/gen-icons.mjs",
    "assets": "node scripts/gen-store-assets.mjs",
    "zip": "yarn build && rm -f mw-creator-stats-extension.zip && cd dist && zip -qr ../mw-creator-stats-extension.zip . && cd .. && echo 'packed -> packages/extension/mw-creator-stats-extension.zip'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/archivo": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@mw/core": "*",
    "@mw/ui": "*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "sharp": "^0.34.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  }
}
