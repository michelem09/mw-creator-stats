# Optional. If set, the dashboard uses this cookie when the UI has none stored.
# Get it from DevTools -> Network -> any makerworld.com request -> Request Headers -> Cookie.
# Format: "name1=value1; name2=value2; ..." (or just "token=..." if MW only needs that one).
MW_COOKIE=

# Optional. Port the dev server / production server listens on. Default is 3617,
# picked to avoid conflicts with the more usual 3000/3001. Override only if you
# need to bind to a specific port.
# PORT=3617

# Optional. If set, the AI Insights drawer falls back to this when the UI has
# no key stored. Useful for shared/Docker setups. Get one at:
#   https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
